# Lumex local dev environment — copy to .env and fill in values
# NEVER commit .env with real secrets

# Stellar
STELLAR_NETWORK=testnet
BRIDGE_SECRET_KEY=YOUR_TESTNET_SECRET_KEY_HERE
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ESCROW_CONTRACT_ADDRESS=
RISK_CONTRACT_ADDRESS=
MULTISIG_CONTRACT_ADDRESS=
DUAL_LEDGER_CONTRACT_ADDRESS=

# MetaApi (MT4/5)
METAAPI_TOKEN=YOUR_METAAPI_TOKEN_HERE
MT4_ACCOUNT_ID=YOUR_DEMO_MT4_ACCOUNT_ID

# Auth
JWT_SECRET=change-me-in-production
WEBHOOK_SECRET=change-me-in-production

# KYC providers (use sandbox keys for dev)
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
ONFIDO_API_TOKEN=

# AML
CHAINALYSIS_API_KEY=

# FX rates
FX_PROVIDER_URL=https://openexchangerates.org/api
FX_API_KEY=

# Database (set by docker-compose — override for external DB)
DATABASE_URL=postgresql://lumex:lumex@localhost:5432/lumex
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
NODE_ENV=development
